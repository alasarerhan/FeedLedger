# ========================================
# FeedLedger Configuration
# ========================================

# AI Provider selection: gemini | openrouter (default: gemini)
AI_PROVIDER=gemini

# Gemini settings (required if AI_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter settings (required if AI_PROVIDER=openrouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=deepseek/deepseek-v3.2-speciale

# Notion (required for daily report persistence)
NOTION_API_KEY=your_notion_api_key_here
NOTION_PARENT_PAGE_ID=your_parent_page_id_here
NOTION_QUOTA_AUTOCLEAN=true

# Telegram (required for daily link notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Mammoth (Mongo-compatible local document database for Reader UI)
MAMMOTH_ENABLED=true
MAMMOTH_URI=mongodb://127.0.0.1:27017
MAMMOTH_DATABASE=feedledger

# Locale
REPORT_TIMEZONE=Europe/Istanbul
DAILY_SCAN_TIME=23:45
DAILY_SEND_TIME=06:00
REPORT_PERIOD_DAYS=1
REPORT_GROUPING_MODE=single
INTEREST_TOPICS=Artificial Intelligence,Machine Learning

# Admin panel
ADMIN_PANEL_PASSWORD=change_me
PANEL_HOST=127.0.0.1
PANEL_PORT=8897

# Pipeline tuning
MAX_ARTICLES_PER_POLL=10
ARXIV_MAX_PER_POLL=15
RELEVANCE_THRESHOLD=6

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Legacy compatibility (not used by daily report pipeline)
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=
POLL_INTERVAL_MINUTES=15
